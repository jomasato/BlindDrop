# Deployer private key (no 0x prefix needed for Hardhat)
PRIVATE_KEY=your_private_key_here

# Deployed contract address (used by frontend)
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYourDeployedContractAddressHere

# RPC endpoints (defaults are already set in hardhat.config.ts)
# LOCAL_FHENIX_RPC=http://127.0.0.1:42069
# HELIUM_RPC=https://api.helium.fhenix.zone
